generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id String @id @default(cuid())

  // Basic info
  name        String
  description String
  price       Float
  category    String
  stock       Int     @default(0)
  imageUrl    String?

  // Condition
  condition       String? // "New" | "Used"
  conditionRating Float?  // 0–10

  // Physical dimensions
  length Float?
  width  Float?
  height Float?
  weight Float?

  // Pricing
  pricingFormat String? @default("Fixed Price") // "Fixed Price" | "Auctions"
  quantity      Int?    @default(1)

  // Shipping & Location
  shippingMethod       String?
  country              String?
  city                 String?
  domesticReturns      Boolean @default(false)
  internationalReturns Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}
